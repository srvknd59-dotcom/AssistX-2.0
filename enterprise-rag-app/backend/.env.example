# Copy this file to .env and fill in your own key.
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Models. If you change EMBED_MODEL, also update EMBED_DIMS to match:
#   text-embedding-3-small -> 1536 (default)
#   text-embedding-3-large -> 3072
EMBED_MODEL=text-embedding-3-small
EMBED_DIMS=1536
CHAT_MODEL=gpt-4o-mini

# Which vector store to use:
#   chroma        -> embedded, no server, just a folder on disk (default)
#   elasticsearch -> a real Elasticsearch server, same engine the production
#                    chat_service.py/ingestor.py in this repo use.
#                    See backend/README_ELASTICSEARCH.md before switching this.
VECTOR_DB_BACKEND=chroma

# Used when VECTOR_DB_BACKEND=chroma. Relative paths are resolved from backend/.
CHROMA_PERSIST_DIR=./chroma_data

# Used when VECTOR_DB_BACKEND=elasticsearch
ES_URL=http://localhost:9200
ES_INDEX_PREFIX=rag
# Leave blank if you disabled security for local dev (see README_ELASTICSEARCH.md)
ES_USERNAME=
ES_PASSWORD=

# Allowed origin(s) for the React dev server (Vite default port), comma-separated
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Retrieval
TOP_K=4
