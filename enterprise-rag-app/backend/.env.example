# Copy this file to .env and fill in your own key.
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Models. If you change EMBED_MODEL, also update EMBED_DIMS to match:
#   text-embedding-3-small -> 1536 (default)
#   text-embedding-3-large -> 3072
EMBED_MODEL=text-embedding-3-small
EMBED_DIMS=1536
CHAT_MODEL=gpt-4o-mini

# Elasticsearch - must be running and reachable before you start the backend.
# See backend/README_ELASTICSEARCH.md for local Windows setup.
ES_URL=http://localhost:9200
ES_INDEX_PREFIX=rag
# Leave blank if you disabled security for local dev (see README_ELASTICSEARCH.md)
ES_USERNAME=
ES_PASSWORD=

# Allowed origin(s) for the React dev server (Vite default port), comma-separated
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Retrieval
TOP_K=4

# PDF images are described by CHAT_MODEL (must be vision-capable, e.g.
# gpt-4o-mini) and indexed as their own searchable chunk. Each image is one
# extra API call during ingestion - turn off or lower the cap for large,
# image-heavy PDFs if cost/ingestion time matters more than image search.
CAPTION_IMAGES=true
MAX_IMAGES_PER_DOCUMENT=20
