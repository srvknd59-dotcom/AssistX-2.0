# Copy this file to .env and fill in your own key.
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Models
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Where Chroma persists its data on disk (a real, on-disk vector database,
# not an in-memory toy). Relative paths are resolved from backend/.
CHROMA_PERSIST_DIR=./chroma_data

# Allowed origin(s) for the React dev server (Vite default port), comma-separated
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Retrieval
TOP_K_PER_COLLECTION=3
